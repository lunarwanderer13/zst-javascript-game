{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "Bundler",

        "rootDir": "./src",
        "outDir": "./dist",

        "strict": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "removeComments": false
    },
    "include": ["src"]
}
